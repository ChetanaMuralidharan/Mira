{
  "tables": [
    {
      "name": "dim_patients",
      "schema": "marts",
      "full_name": "main_marts.dim_patients",
      "description": "Central patient dimension. One row per patient with demographics, chronic condition flags, and most recent key lab values. Condition flags are precomputed \u2014 no need to join conditions for basic counts.\n",
      "columns": [
        {
          "name": "patient_id",
          "description": "Unique patient identifier",
          "data_type": "VARCHAR"
        },
        {
          "name": "birth_date",
          "description": "",
          "data_type": "DATE"
        },
        {
          "name": "death_date",
          "description": "",
          "data_type": "DATE"
        },
        {
          "name": "gender",
          "description": "",
          "data_type": "VARCHAR"
        },
        {
          "name": "race",
          "description": "",
          "data_type": "VARCHAR"
        },
        {
          "name": "ethnicity",
          "description": "",
          "data_type": "VARCHAR"
        },
        {
          "name": "city",
          "description": "",
          "data_type": "VARCHAR"
        },
        {
          "name": "state",
          "description": "",
          "data_type": "VARCHAR"
        },
        {
          "name": "income",
          "description": "",
          "data_type": "BIGINT"
        },
        {
          "name": "is_deceased",
          "description": "",
          "data_type": "BOOLEAN"
        },
        {
          "name": "age_at_generation",
          "description": "",
          "data_type": "BIGINT"
        },
        {
          "name": "age_bucket",
          "description": "",
          "data_type": "VARCHAR"
        },
        {
          "name": "healthcare_expenses",
          "description": "",
          "data_type": "DOUBLE"
        },
        {
          "name": "healthcare_coverage",
          "description": "",
          "data_type": "DOUBLE"
        },
        {
          "name": "has_diabetes",
          "description": "1 if patient has active Type 2 diabetes (ICD-10 E11.*), 0 otherwise.",
          "data_type": "INTEGER"
        },
        {
          "name": "has_hypertension",
          "description": "1 if patient has active essential hypertension (ICD-10 I10), 0 otherwise.",
          "data_type": "INTEGER"
        },
        {
          "name": "has_copd",
          "description": "",
          "data_type": "INTEGER"
        },
        {
          "name": "has_heart_failure",
          "description": "",
          "data_type": "INTEGER"
        },
        {
          "name": "has_ckd",
          "description": "",
          "data_type": "INTEGER"
        },
        {
          "name": "has_asthma",
          "description": "",
          "data_type": "INTEGER"
        },
        {
          "name": "latest_a1c_value",
          "description": "Most recent A1c value in percent. NULL if never recorded. Normal below 5.7%. Prediabetes 5.7-6.4%. Diabetes 6.5%+.\n",
          "data_type": "FLOAT"
        },
        {
          "name": "latest_bmi_value",
          "description": "",
          "data_type": "FLOAT"
        }
      ]
    },
